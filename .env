# COVORA App — API Configuration
# Set this to your COMODO MASTER BACKEND base URL.
# Leave empty to run the app on mock/offline data.
EXPO_PUBLIC_API_BASE_URL=https://covorabackend.zeabur.app/api/v1

# Optional: API key for backend authentication
EXPO_PUBLIC_API_KEY=

# Optional: Store/tenant identifier for multi-tenant backends
EXPO_PUBLIC_STORE_ID=covora
